# Required deployment target and region for newly provisioned resources.
AZURE_RESOURCE_GROUP="<rg-name>"
AZURE_LOCATION="<azure-region>"

# Optional separate Foundry account/project/model region; defaults to AZURE_LOCATION.
AZURE_AI_DEPLOYMENTS_LOCATION=""

# Required model selection. When changing or provisioning a model, configure all
# five values together. Empty values retain metadata from azure.yaml and can mix
# an existing model's format/version/capacity with the new model.
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4-mini"
AZURE_AI_MODEL_NAME="gpt-5.4-mini"
AZURE_AI_MODEL_FORMAT="OpenAI"
AZURE_AI_MODEL_DEPLOYMENT_VERSION="2026-03-17"
AZURE_AI_MODEL_DEPLOYMENT_CAPACITY="500"

# Required project name and optional account selector. The project name is exact:
# deploy.sh reuses that name when found or provisions that name when missing.
# Leave the account empty to search all Foundry accounts in the resource group.
AZURE_AI_ACCOUNT_NAME=""
AZURE_AI_AGENT_NAME="security-investigator-copilot-agent"
AZURE_AI_PROJECT_NAME="ps-default"
AZURE_AI_PROJECT_ID=""

# Auto-loaded by deploy.sh (takes precedence over .env.example).
FOUNDRY_PROJECT_ENDPOINT=""

# Runtime values. deploy.sh resolves the project endpoint from ARM/provision
# output and derives the Toolbox and Azure OpenAI endpoints from that project.
TOOLBOX_MCP_NAME="ps-toolbox-default"
TOOLBOX_MCP_ENDPOINT=""

# Azure OpenAI data-plane endpoint for the Copilot BYOK provider.
# If unset, main.py derives it from FOUNDRY_PROJECT_ENDPOINT.
AZURE_OPENAI_ENDPOINT=""

# Optional Copilot SDK / runtime tunables
AZURE_OPENAI_API_VERSION="2024-10-21"
COPILOT_WIRE_API=""
COPILOT_LOG_LEVEL="info"
COPILOT_GITHUB_TOKEN=""
GH_TOKEN=""
LOG_LEVEL="INFO"

# Optional container sizing (defaults: 2 / 4Gi)
AGENT_CPU="2"
AGENT_MEMORY="4Gi"

# Optional reuse an existing ACR
AZURE_CONTAINER_REGISTRY_NAME=""
