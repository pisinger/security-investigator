# Identity / infra seed (deploy.sh syncs these into the azd env; keep ids on one line).
AZURE_RESOURCE_GROUP="ps-rg-foundry-1"
AZURE_LOCATION="germanywestcentral"

# Optional separate Foundry account/project/model region; defaults to AZURE_LOCATION.
AZURE_AI_DEPLOYMENTS_LOCATION=""

# Exact project name to reuse or create. Leave account empty to search all
# Foundry accounts in the resource group. IDs/endpoints are deployment outputs.
AZURE_AI_ACCOUNT_NAME=""
AZURE_AI_AGENT_NAME="security-investigator-agent-framework"
AZURE_AI_PROJECT_NAME="ps-default"
AZURE_AI_PROJECT_ID=""
AZURE_AI_PROJECT_ENDPOINT=""

# Auto-loaded by deploy.sh (takes precedence over .env.example).
FOUNDRY_PROJECT_ENDPOINT=""

# Must match an existing model deployment in the project.
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4-mini"
AZURE_AI_MODEL_NAME="gpt-5.4-mini"
AZURE_AI_MODEL_FORMAT="OpenAI"
AZURE_AI_MODEL_DEPLOYMENT_VERSION="2026-03-17"
# Capacity is in UNITS where 1 unit = 1,000 TPM (tokens/min).
AZURE_AI_MODEL_DEPLOYMENT_CAPACITY="500"

# Use the default toolbox version; v1/v2 pin requires agent re-deploy on toolbox change.
TOOLBOX_MCP_NAME="ps-toolbox-default"
TOOLBOX_MCP_ENDPOINT=""

# --- Agent Framework harness ---
# FoundryChatClient talks to the project endpoint (FOUNDRY_PROJECT_ENDPOINT), so there
# is no AZURE_OPENAI_ENDPOINT / BYOK provider wiring here. The workspace context the
# skills assume is read from config.json and injected into the instructions by main.py
# at startup.

# Reuse this existing Azure Container Registry instead of creating a new one.
# AZURE_CONTAINER_REGISTRY_NAME=<acr-name>

# Hosted agent container size (vCPU / memory). Valid pairs e.g. 1/2Gi, 2/4Gi, 4/8Gi.
AGENT_CPU=1
AGENT_MEMORY=2Gi

# Python root logger level.
LOG_LEVEL="INFO"
